class MCPServer:
    """MCP server that proxies tool calls to the Chrome extension via Unix socket."""

    def __init__(self, preferred_socket: str | None = None):
        self.running = True
        self.socket_reader: asyncio.StreamReader | None = None
        self.socket_writer: asyncio.StreamWriter | None = None
        self.socket_connected = False
        self.current_socket_path: str | None = None
        self.preferred_socket: str | None = preferred_socket or PREFERRED_SOCKET_ENV
        self.pending_requests: dict[str | int, asyncio.Future] = {}
        self.request_counter = 0
        self.socket_buf = b""
        self.stdin_buf = b""
        # Per-MCP-run session id. Passed as session_scope so the extension uses
        # session-scoped tab groups (auto-cleanable) instead of the legacy shared one.
        self.session_id = uuid.uuid4().hex
        # Active tab tracking for auto-injection
        self.active_tab_id: int | None = None
        self.tab_group_id: int | None = None
        self.tab_group_initialized = False

    # -- stdio helpers (MCP JSON-RPC) -----------------------------------------

    def _write_stdout(self, msg: dict) -> None:
        """Write a JSON-RPC message to stdout for Claude Code."""
        data = json.dumps(msg, separators=(",", ":")) + "\n"
        sys.stdout.write(data)
        sys.stdout.flush()

    # -- Socket communication (4-byte LE length prefix + JSON) ----------------

    def _find_socket_paths(self) -> list[str]:
        """Find all available socket files in the socket directory."""
        paths = []
        if not os.path.isdir(SOCKET_DIR):
            return paths
        try:
            for name in sorted(os.listdir(SOCKET_DIR)):
                if name.endswith(".sock"):
                    paths.append(os.path.join(SOCKET_DIR, name))
        except OSError:
            pass
        return paths

    def _resolve_preferred_socket(self) -> str | None:
        """Turn a partial preferred-socket spec (path or filename) into an absolute path."""
        s = self.preferred_socket
        if not s:
            return None
        if os.path.isabs(s):
            return s
        return os.path.join(SOCKET_DIR, s)

    async def _connect_socket(self) -> bool:
        """Connect to the chrome-native-host Unix socket.

        If a preferred socket is configured, try it exclusively. Otherwise fall back to
        the first .sock that accepts a connection.
        """
        preferred = self._resolve_preferred_socket()
        if preferred:
            candidates = [preferred]
        else:
            candidates = self._find_socket_paths()
        if not candidates:
            log.warning("No sockets found in %s", SOCKET_DIR)
            return False
        for path in candidates:
            try:
                self.socket_reader, self.socket_writer = (
                    await asyncio.open_unix_connection(path)
                )
                self.socket_connected = True
                self.current_socket_path = path
                log.info("Connected to chrome-native-host socket at %s", path)
                return True
            except Exception as exc:
                log.debug("Failed to connect to socket %s: %s", path, exc)
                continue
        if preferred:
            log.warning("Preferred socket %s could not be reached", preferred)
        else:
            log.warning("Could not connect to any socket in %s", SOCKET_DIR)
        self.socket_connected = False
        return False

    def _list_profiles_result(self) -> dict:
        """Return an MCP text result describing the candidate sockets."""
        paths = self._find_socket_paths()
        if not paths:
            return self._text_result(
                f"No Chrome profiles connected. Socket directory {SOCKET_DIR} has no .sock files. "
                f"Make sure Chrome is running with the 'Claude in Chrome' extension installed."
            )
        lines = [f"Socket directory: {SOCKET_DIR}"]
        for p in paths:
            marker = "  * " if p == self.current_socket_path else "    "
            lines.append(f"{marker}{os.path.basename(p)}  ({p})")
        lines.append("")
        lines.append("'*' marks the currently active socket. Use browser_select_profile to switch.")
        return self._text_result("\n".join(lines))

    async def _switch_socket(self, target: str) -> dict:
        """Disconnect from the current socket and reconnect to `target`.

        `target` may be a full path or just a filename inside SOCKET_DIR.
        Returns an MCP result dict describing the outcome.
        """
        resolved = target if os.path.isabs(target) else os.path.join(SOCKET_DIR, target)
        if not os.path.exists(resolved):
            return self._error_result(f"Socket not found: {resolved}")

        # Close the existing socket, drop tab-group cache, set preference, reconnect.
        await self._close_socket()
        self.preferred_socket = resolved
        self._reset_tab_group_state()
        if not await self._connect_socket():
            return self._error_result(f"Could not connect to {resolved}")
        asyncio.get_running_loop().create_task(self._read_socket_loop())
        return self._text_result(f"Connected to {resolved}")

    async def _close_socket(self) -> None:
        """Cleanly close the current socket connection if any."""
        writer = self.socket_writer
        self.socket_connected = False
        self.socket_reader = None
        self.socket_writer = None
        # Cancel pending requests so callers don't hang.
        for fut in list(self.pending_requests.values()):
            if not fut.done():
                fut.cancel()
        self.pending_requests.clear()
        if writer is not None:
            try:
                writer.close()
                await writer.wait_closed()
            except Exception:
                pass

    def _write_socket(self, msg: dict) -> None:
        """Send a message to chrome-native-host via the Unix socket."""
        if self.socket_writer is None:
            log.warning("Socket not connected, cannot send message")
            return
        try:
            data = json.dumps(msg, separators=(",", ":")).encode("utf-8")
            header = struct.pack("<I", len(data))
            self.socket_writer.write(header + data)
            log.debug("Sent to socket: %s", msg)
        except Exception:
            log.exception("Failed to write to socket")
            self.socket_connected = False

    async def _send_and_wait(self, tool: str, args: dict, timeout: float = 30.0) -> dict:
        """Send a tool request to the socket and wait for the response."""
        self.request_counter += 1
        req_key = self.request_counter
        future: asyncio.Future = asyncio.get_running_loop().create_future()
        self.pending_requests[req_key] = future

        # `session_scope` tells the extension to use a session-scoped tab group
        # (auto-cleaned) instead of the legacy shared one.
        params: dict = {
            "tool": tool,
            "args": args,
            "session_scope": {"sessionId": self.session_id},
        }
        if self.tab_group_id is not None and "tabGroupId" not in args:
            args["tabGroupId"] = self.tab_group_id

        self._write_socket({"method": "execute_tool", "params": params})

        try:
            return await asyncio.wait_for(future, timeout=timeout)
        except asyncio.TimeoutError:
            self.pending_requests.pop(req_key, None)
            return {"error": {"content": f"Timed out ({timeout}s)"}}

    async def _read_socket_loop(self) -> None:
        """Read messages from the Unix socket and dispatch responses."""
        buf = b""
        try:
            while self.running and self.socket_reader:
                data = await self.socket_reader.read(65536)
                if not data:
                    log.info("Socket disconnected (EOF)")
                    break
                buf += data
                while len(buf) >= 4:
                    length = struct.unpack("<I", buf[:4])[0]
                    if length > 1024 * 1024:
                        log.error("Socket message too large (%d bytes), dropping", length)
                        buf = b""
                        break
                    if len(buf) < 4 + length:
                        break
                    payload = buf[4 : 4 + length]
                    buf = buf[4 + length :]
                    try:
                        msg = json.loads(payload)
                        self._handle_socket_response(msg)
                    except Exception:
                        log.exception("Failed to parse socket message")
        except asyncio.CancelledError:
            pass
        except Exception:
            log.exception("Socket read error")
        finally:
            self.socket_connected = False
            log.info("Socket read loop ended")

    def _handle_socket_response(self, msg: dict) -> None:
        """Handle a response from the Chrome extension via socket."""
        log.debug("Socket response: %s", msg)
        if "result" not in msg and "error" not in msg:
            log.debug("Ignoring non-tool-response message: %s", msg)
            return
        for req_id, future in list(self.pending_requests.items()):
            if not future.done():
                future.set_result(msg)
                del self.pending_requests[req_id]
                break

    # -- Tab group initialization ---------------------------------------------

    async def _ensure_tab_group(self) -> bool:
        """Initialize MCP tab group if not yet done. Returns True if ready."""
        if self.tab_group_initialized and self.active_tab_id is not None:
            return True

        if not self.socket_connected:
            return False

        # Reset stale state before re-initializing
        self._reset_tab_group_state()

        # Call tabs_context_mcp with createIfEmpty to initialize or retrieve
        result = await self._send_and_wait(
            "tabs_context_mcp", {"createIfEmpty": True}
        )
        if "error" in result:
            log.warning("Failed to init tab group: %s", result["error"])
            return False

        # Parse tab info from response
        self._parse_tab_context(result)
        return self.active_tab_id is not None

    def _parse_tab_context(self, result: dict) -> None:
        """Extract tabId and tabGroupId from a tabs_context_mcp response."""
        try:
            content = result.get("result", {}).get("content", [])
            for item in content:
                if isinstance(item, dict) and item.get("type") == "text":
                    text = item["text"]
                    # Try parsing as JSON (first content block)
                    try:
                        data = json.loads(text)
                        tabs = data.get("availableTabs", [])
                        if tabs:
                            # Pick the first non-chrome:// tab, or first tab
                            for tab in tabs:
                                url = tab.get("url", "")
                                if not url.startswith("chrome://"):
                                    self.active_tab_id = self._extract_tab_id(tab)
                                    break
                            if self.active_tab_id is None:
                                self.active_tab_id = self._extract_tab_id(tabs[0])
                        if "tabGroupId" in data:
                            self.tab_group_id = data["tabGroupId"]
                        self.tab_group_initialized = True
                        log.info(
                            "Tab group initialized: tabId=%s groupId=%s",
                            self.active_tab_id, self.tab_group_id,
                        )
                        return
                    except (json.JSONDecodeError, KeyError):
                        continue
        except Exception:
            log.exception("Failed to parse tab context")

    @staticmethod
    def _extract_tab_id(tab: dict):
        """tabs_context_mcp returns 'id', other responses use 'tabId' — accept both."""
        return tab.get("tabId", tab.get("id"))

    def _update_active_tab_from_response(self, result: dict) -> None:
        """Update active_tab_id from tool response Tab Context info."""
        try:
            content = result.get("result", {}).get("content", [])
            for item in content:
                if isinstance(item, dict) and item.get("type") == "text":
                    text = item["text"]
                    if "Executed on tabId:" in text:
                        m = re.search(r"Executed on tabId:\s*(\d+)", text)
                        if m:
                            self.active_tab_id = int(m.group(1))
                    # Also check for new tabs in context
                    if "tabId" in text:
                        try:
                            data = json.loads(text)
                            tabs = data.get("availableTabs", [])
                            if tabs:
                                for tab in tabs:
                                    url = tab.get("url", "")
                                    if not url.startswith("chrome://"):
                                        self.active_tab_id = tab["tabId"]
                                        break
                        except (json.JSONDecodeError, KeyError):
                            pass
        except Exception:
            pass

    def _reset_tab_group_state(self) -> None:
        """Forget the cached MCP tab group so the next call re-initializes it."""
        self.active_tab_id = None
        self.tab_group_id = None
        self.tab_group_initialized = False

    def _inject_tab_id(self, internal_name: str, tool_args: dict) -> dict:
        """Return a copy of tool_args with the active tabId injected when needed."""
        out = dict(tool_args)
        if internal_name not in NO_TABID_TOOLS and "tabId" not in out and self.active_tab_id is not None:
            out["tabId"] = self.active_tab_id
        return out

    # -- MCP tool -> Chrome extension tool translation ------------------------

    @staticmethod
    def _text_result(text: str) -> dict:
        """An MCP tool result carrying a plain text message."""
        return {"content": [{"type": "text", "text": text}]}

    @staticmethod
    def _error_result(text: str) -> dict:
        """An MCP tool result flagged as an error."""
        return {"content": [{"type": "text", "text": f"Error: {text}"}], "isError": True}

    @staticmethod
    def _js_call(expr: str) -> tuple:
        """A javascript_tool call that evaluates a single JS expression."""
        return ("javascript_tool", {"action": "javascript_exec", "text": expr})

    def _translate_call(self, mcp_name: str, args: dict):
        """Translate an MCP browser_* call into Chrome-extension tool call(s).

        Returns (calls, local_result):
          - calls: list of (internal_tool_name, internal_args) to run in order;
            the result of the last one is returned to the MCP client.
          - local_result: if not None, an MCP result dict to return directly
            without contacting the extension (and `calls` is ignored).
        """
        a = dict(args or {})

        if mcp_name == "browser_navigate":
            return [("navigate", {"url": a.get("url")})], None

        if mcp_name == "browser_tab_list":
            return [("tabs_context_mcp", {})], None

        if mcp_name == "browser_tab_new":
            calls = [("tabs_create_mcp", {})]
            if a.get("url"):
                # navigate runs on the freshly-created (now active) tab
                calls.append(("navigate", {"url": a["url"]}))
            return calls, None

        if mcp_name == "browser_tab_close":
            tab_id = a.get("tabId", self.active_tab_id)
            if tab_id is None:
                return [], self._error_result("browser_tab_close requires a tabId")
            return [("tabs_close_mcp", {"tabId": int(tab_id)})], None

        if mcp_name == "browser_tab_switch":
            tab_id = a.get("tabId")
            if tab_id is None:
                return [], self._error_result("browser_tab_switch requires a tabId")
            self.active_tab_id = int(tab_id)
            return [], self._text_result(f"Active tab set to {tab_id}")

        if mcp_name == "browser_snapshot":
            ia = {}
            if a.get("filter") in ("interactive", "all"):
                ia["filter"] = a["filter"]
            return [("read_page", ia)], None

        if mcp_name == "browser_console_messages":
            ia = {}
            if a.get("onlyErrors"):
                ia["onlyErrors"] = True
            if a.get("pattern"):
                ia["pattern"] = a["pattern"]
            return [("read_console_messages", ia)], None

        if mcp_name == "browser_js_eval":
            return [self._js_call(a.get("code", ""))], None

        if mcp_name == "browser_screen_capture":
            return [("computer", {"action": "screenshot"})], None

        if mcp_name == "browser_scroll":
            # `computer` scroll needs pixel coordinates; doing it in-page is simpler.
            # Schema only exposes vertical scrolling ("up" / "down").
            direction = a.get("direction", "down")
            amount = a.get("amount")
            magnitude = str(int(amount)) if amount else "window.innerHeight"
            sign = "-" if direction == "up" else ""
            expr = (f"(function(){{window.scrollBy(0, {sign}{magnitude});"
                    f"return 'scrolled {direction} (now at y='+Math.round(window.scrollY)+')';}})()")
            return [self._js_call(expr)], None

        if mcp_name == "browser_click":
            button = a.get("button", "left")
            clicks = int(a.get("clicks", 1) or 1)
            modifiers = a.get("modifiers")
            if button == "right":
                action = "right_click"
            elif clicks == 3:
                action = "triple_click"
            elif clicks == 2:
                action = "double_click"
            else:
                action = "left_click"
            ia: dict = {"action": action}
            if modifiers:
                ia["modifiers"] = modifiers
            if a.get("ref"):
                ia["ref"] = a["ref"]
                return [("computer", ia)], None
            if a.get("x") is not None and a.get("y") is not None:
                ia["coordinate"] = [a["x"], a["y"]]
                return [("computer", ia)], None
            if a.get("selector"):
                # No native selector path; fall back to JS click. Only honors single left-click.
                if action != "left_click" or modifiers:
                    return [], self._error_result(
                        "browser_click: 'selector' only supports single left-click without modifiers; use 'ref' or 'x'/'y' instead"
                    )
                sel = json.dumps(a["selector"])
                expr = (f"(function(){{var el=document.querySelector({sel});"
                        f"if(!el)throw new Error('Element not found: '+{sel});"
                        f"el.scrollIntoView({{block:'center',inline:'center'}});el.click();"
                        f"return 'clicked '+el.tagName.toLowerCase();}})()")
                return [self._js_call(expr)], None
            return [], self._error_result("browser_click requires 'ref', 'selector', or 'x'+'y'")

        if mcp_name == "browser_hover":
            ia = {"action": "hover"}
            if a.get("ref"):
                ia["ref"] = a["ref"]
            elif a.get("x") is not None and a.get("y") is not None:
                ia["coordinate"] = [a["x"], a["y"]]
            else:
                return [], self._error_result("browser_hover requires 'ref' or 'x'+'y'")
            return [("computer", ia)], None

        if mcp_name == "browser_drag":
            for k in ("from_x", "from_y", "to_x", "to_y"):
                if a.get(k) is None:
                    return [], self._error_result(f"browser_drag requires '{k}'")
            return [("computer", {
                "action": "left_click_drag",
                "start_coordinate": [a["from_x"], a["from_y"]],
                "coordinate": [a["to_x"], a["to_y"]],
            })], None

        if mcp_name == "browser_press_key":
            text = a.get("text")
            if not text:
                return [], self._error_result("browser_press_key requires 'text'")
            ia = {"action": "key", "text": text}
            if a.get("repeat"):
                ia["repeat"] = int(a["repeat"])
            return [("computer", ia)], None

        if mcp_name == "browser_wait":
            sec = a.get("seconds")
            if sec is None:
                return [], self._error_result("browser_wait requires 'seconds'")
            return [("computer", {"action": "wait", "duration": float(sec)})], None

        if mcp_name == "browser_zoom":
            for k in ("x0", "y0", "x1", "y1"):
                if a.get(k) is None:
                    return [], self._error_result(f"browser_zoom requires '{k}'")
            return [("computer", {
                "action": "zoom",
                "region": [a["x0"], a["y0"], a["x1"], a["y1"]],
            })], None

        if mcp_name == "browser_scroll_to":
            if not a.get("ref"):
                return [], self._error_result("browser_scroll_to requires 'ref'")
            return [("computer", {"action": "scroll_to", "ref": a["ref"]})], None

        if mcp_name == "browser_resize_window":
            w, h = a.get("width"), a.get("height")
            if not w or not h:
                return [], self._error_result("browser_resize_window requires 'width' and 'height'")
            return [("resize_window", {"width": int(w), "height": int(h)})], None

        if mcp_name == "browser_get_page_text":
            ia = {}
            if a.get("max_chars"):
                ia["max_chars"] = int(a["max_chars"])
            return [("get_page_text", ia)], None

        if mcp_name == "browser_network_requests":
            ia = {}
            if a.get("urlPattern"):
                ia["urlPattern"] = a["urlPattern"]
            if a.get("clear"):
                ia["clear"] = True
            if a.get("limit"):
                ia["limit"] = int(a["limit"])
            return [("read_network_requests", ia)], None

        if mcp_name == "browser_form_input":
            if not a.get("ref") or a.get("value") is None:
                return [], self._error_result("browser_form_input requires 'ref' and 'value'")
            return [("form_input", {"ref": a["ref"], "value": a["value"]})], None

        if mcp_name == "browser_upload_image":
            if not a.get("imageId"):
                return [], self._error_result("browser_upload_image requires 'imageId'")
            ia = {"imageId": a["imageId"]}
            if a.get("ref"):
                ia["ref"] = a["ref"]
            elif a.get("x") is not None and a.get("y") is not None:
                ia["coordinate"] = [a["x"], a["y"]]
            else:
                return [], self._error_result("browser_upload_image requires 'ref' or 'x'+'y'")
            if a.get("filename"):
                ia["filename"] = a["filename"]
            return [("upload_image", ia)], None

        if mcp_name == "browser_file_upload":
            if not a.get("ref") or not isinstance(a.get("files"), list):
                return [], self._error_result("browser_file_upload requires 'ref' and 'files' (list)")
            return [("file_upload", {"ref": a["ref"], "files": a["files"]})], None

        if mcp_name == "browser_list_profiles":
            return [], self._list_profiles_result()

        # browser_select_profile is handled directly in _handle_tools_call (needs await).
        # Falling through here would treat it as unknown.

        if mcp_name == "browser_type":
            text = a.get("text", "")
            calls = []
            if a.get("ref"):
                # The extension's own form-fill tool (works for inputs/selects/checkboxes).
                calls.append(("form_input", {"ref": a["ref"], "value": text}))
            elif a.get("selector"):
                sel = json.dumps(a["selector"])
                val = json.dumps(text)
                expr = (
                    f"(function(){{var el=document.querySelector({sel});"
                    f"if(!el)throw new Error('Element not found: '+{sel});el.focus();"
                    f"if(el.isContentEditable){{document.execCommand('insertText',false,{val});}}"
                    f"else if('value' in el){{var p=el instanceof HTMLTextAreaElement?"
                    f"HTMLTextAreaElement.prototype:HTMLInputElement.prototype;"
                    f"var s=Object.getOwnPropertyDescriptor(p,'value').set;"
                    f"s.call(el,(el.value||'')+{val});"
                    f"el.dispatchEvent(new Event('input',{{bubbles:true}}));"
                    f"el.dispatchEvent(new Event('change',{{bubbles:true}}));}}"
                    f"else{{throw new Error('Element <'+el.tagName.toLowerCase()+'> is not typeable');}}"
                    f"return 'typed into <'+el.tagName.toLowerCase()+'>';}})()"
                )
                calls.append(self._js_call(expr))
            else:
                # Type into whatever element currently has focus.
                calls.append(("computer", {"action": "type", "text": text}))
            if a.get("pressEnter"):
                calls.append(("computer", {"action": "key", "text": "Return"}))
            return calls, None

        # Unknown tool: pass through unchanged.
        return [(mcp_name, a)], None

    async def _run_call_chain(self, calls: list, _retried: bool = False) -> dict:
        """Run a sequence of (internal_name, args) calls; return the last result.

        Stops at the first error. If the extension reports the cached tab group
        is stale, re-initializes it once and re-runs the whole chain.
        """
        result: dict = {"result": {"content": []}}
        for internal_name, raw_args in calls:
            args = self._inject_tab_id(internal_name, raw_args)
            result = await self._send_and_wait(internal_name, args, timeout=60.0)
            if self._is_stale_tab_error(result) and not _retried:
                log.warning("Stale tab group on %s; re-initializing and retrying", internal_name)
                self._reset_tab_group_state()
                if await self._ensure_tab_group():
                    return await self._run_call_chain(calls, _retried=True)
            if "error" in result:
                return result
            self._update_active_tab_from_response(result)
        return result

    @staticmethod
    def _is_stale_tab_error(result: dict) -> bool:
        """True if the socket response means the cached tab/group no longer exists."""
        err = result.get("error")
        if not err:
            return False
        if isinstance(err, dict):
            err = err.get("content", err)
        text = err if isinstance(err, str) else json.dumps(err, ensure_ascii=False)
        return any(marker in text for marker in STALE_TAB_ERROR_MARKERS)

    # -- Socket reconnection --------------------------------------------------

    async def _maintain_socket_connection(self) -> None:
        """Background task to maintain socket connection with reconnection."""
        interval = RECONNECT_INTERVAL
        while self.running:
            if not self.socket_connected:
                # Reset cached tab state so we re-initialize after reconnect
                self._reset_tab_group_state()
                if await self._connect_socket():
                    interval = RECONNECT_INTERVAL
                    asyncio.get_running_loop().create_task(self._read_socket_loop())
                else:
                    interval = min(interval * 1.5, MAX_RECONNECT_INTERVAL)
            await asyncio.sleep(interval)

    # -- MCP protocol handlers ------------------------------------------------

    def _handle_initialize(self, request: dict) -> dict:
        """Handle MCP initialize request."""
        return {
            "jsonrpc": "2.0",
            "id": request.get("id"),
            "result": {
                "protocolVersion": "2024-11-05",
                "capabilities": {
                    "tools": {},
                },
                "serverInfo": {
                    "name": "chrome-browser-mcp",
                    "version": "1.3.0",
                },
            },
        }

    def _handle_initialized(self, request: dict) -> None:
        """Handle MCP initialized notification (no response needed)."""
        log.info("MCP client initialized")

    def _handle_tools_list(self, request: dict) -> dict:
        """Handle MCP tools/list request."""
        return {
            "jsonrpc": "2.0",
            "id": request.get("id"),
            "result": {
                "tools": BROWSER_TOOLS,
            },
        }

    async def _handle_tools_call(self, request: dict) -> dict:
        """Handle MCP tools/call by translating it into Chrome-extension tool call(s)."""
        params = request.get("params", {})
        tool_name = params.get("name", "")
        tool_args = params.get("arguments", {}) or {}
        request_id = request.get("id")

        log.info("Tool call: %s(%s)", tool_name, json.dumps(tool_args))

        def reply(result: dict) -> dict:
            return {"jsonrpc": "2.0", "id": request_id, "result": result}

        # Profile-switching needs an await before/after the socket reconnect,
        # so it's handled inline rather than via _translate_call.
        if tool_name == "browser_select_profile":
            target = tool_args.get("socket")
            if not target:
                return reply(self._error_result("browser_select_profile requires 'socket'"))
            return reply(await self._switch_socket(target))

        if not self.socket_connected:
            return reply(self._error_result(
                "Chrome extension is not connected. Make sure Chrome is running with the "
                "'Claude in Chrome' extension and the chrome-native-host bridge is active."))

        # Translate the MCP call into one or more Chrome-extension tool calls.
        calls, local_result = self._translate_call(tool_name, tool_args)
        if local_result is not None:
            return reply(local_result)
        if not calls:
            return reply(self._error_result(f"Unsupported tool: {tool_name}"))

        # The extension requires an MCP tab group to exist before any call.
        if not await self._ensure_tab_group():
            return reply(self._error_result(
                "Could not initialize the MCP tab group. Make sure Chrome has at least one tab open."))

        result = await self._run_call_chain(calls)

        if "error" in result:
            err = result["error"]
            if isinstance(err, dict):
                err = err.get("content", err)
            err_text = err if isinstance(err, str) else json.dumps(err, ensure_ascii=False)
            return reply(self._error_result(err_text))

        # Format the extension's result for the MCP client.
        tool_result = result.get("result", {})
        content = tool_result.get("content", tool_result) if isinstance(tool_result, dict) else tool_result
        if isinstance(content, list):
            # The extension returns images in Anthropic message shape
            # ({"type":"image","source":{"type":"base64","media_type":"...","data":"..."}}),
            # but MCP wants flat {"type":"image","data":"...","mimeType":"..."}.
            mcp_content = []
            for item in content:
                if (isinstance(item, dict)
                        and item.get("type") == "image"
                        and isinstance(item.get("source"), dict)):
                    source = item["source"]
                    mcp_content.append({
                        "type": "image",
                        "data": source.get("data", ""),
                        "mimeType": source.get("media_type", "image/png"),
                    })
                else:
                    mcp_content.append(item)
        elif isinstance(content, str):
            mcp_content = [{"type": "text", "text": content}]
        else:
            mcp_content = [{"type": "text", "text": json.dumps(content, indent=2, ensure_ascii=False)}]
        return reply({"content": mcp_content})

    async def _handle_ping(self, request: dict) -> dict:
        """Handle MCP ping request."""
        return {
            "jsonrpc": "2.0",
            "id": request.get("id"),
            "result": {},
        }

    # -- Main stdin processing ------------------------------------------------

    async def _process_stdin_line(self, line: str) -> None:
        """Process a single JSON-RPC message from stdin."""
        line = line.strip()
        if not line:
            return

        try:
            request = json.loads(line)
        except json.JSONDecodeError as exc:
            log.error("Failed to parse JSON-RPC message: %s", exc)
            return

        method = request.get("method", "")
        log.debug("MCP request: method=%s id=%s", method, request.get("id"))

        response = None

        if method == "initialize":
            response = self._handle_initialize(request)
        elif method == "notifications/initialized":
            self._handle_initialized(request)
        elif method == "tools/list":
            response = self._handle_tools_list(request)
        elif method == "tools/call":
            response = await self._handle_tools_call(request)
        elif method == "ping":
            response = await self._handle_ping(request)
        elif method == "notifications/cancelled":
            cancelled_id = request.get("params", {}).get("requestId")
            if cancelled_id and cancelled_id in self.pending_requests:
                future = self.pending_requests.pop(cancelled_id)
                if not future.done():
                    future.cancel()
            log.info("Request %s cancelled", cancelled_id)
        else:
            if "id" in request:
                response = {
                    "jsonrpc": "2.0",
                    "id": request.get("id"),
                    "error": {
                        "code": -32601,
                        "message": f"Method not found: {method}",
                    },
                }
            else:
                log.debug("Ignoring unknown notification: %s", method)

        if response is not None:
            self._write_stdout(response)

    async def _read_stdin_loop(self) -> None:
        """Read JSON-RPC messages from stdin (line-delimited)."""
        loop = asyncio.get_running_loop()
        reader = asyncio.StreamReader()
        protocol = asyncio.StreamReaderProtocol(reader)
        await loop.connect_read_pipe(lambda: protocol, sys.stdin)

        try:
            while self.running:
                line = await reader.readline()
                if not line:
                    log.info("stdin EOF, shutting down")
                    break
                await self._process_stdin_line(line.decode("utf-8"))
        except asyncio.CancelledError:
            pass
        except Exception:
            log.exception("stdin read error")
        finally:
            self.running = False

    # -- Lifecycle ------------------------------------------------------------

    def _shutdown(self) -> None:
        self.running = False

    async def run(self) -> None:
        """Main entry point."""
        log.info("Claude Code Chrome MCP server starting (session %s)", self.session_id[:8])

        # Log discovered sockets up front so the user knows what's available.
        paths = self._find_socket_paths()
        if paths:
            log.info("Available Chrome sockets in %s:", SOCKET_DIR)
            for p in paths:
                log.info("  %s", p)
        if self.preferred_socket:
            log.info("Preferred socket: %s", self._resolve_preferred_socket())

        # Start background socket connection maintainer
        socket_task = asyncio.create_task(self._maintain_socket_connection())

        # Process stdin
        try:
            await self._read_stdin_loop()
        finally:
            self.running = False
            socket_task.cancel()
            try:
                await socket_task
            except asyncio.CancelledError:
                pass
            await self._close_socket()
            log.info("Claude Code Chrome MCP server stopped")


def _parse_args(argv: list[str]) -> argparse.Namespace:
    p = argparse.ArgumentParser(
        prog="claude-code-chrome-mcp",
        description="MCP bridge to the 'Claude in Chrome' extension over a Unix socket.",
    )
    p.add_argument("--socket", metavar="PATH",
                   help="Connect to this socket only (full path or filename inside the socket dir). "
                        "Defaults to env CHROME_MCP_SOCKET, otherwise tries each .sock in the directory.")
    p.add_argument("--list-sockets", action="store_true",
                   help="List the candidate sockets and exit (does not start the server).")
    return p.parse_args(argv)


def main() -> None:
    args = _parse_args(sys.argv[1:])

    if args.list_sockets:
        if not os.path.isdir(SOCKET_DIR):
            print(f"Socket directory does not exist: {SOCKET_DIR}", file=sys.stderr)
            sys.exit(1)
        names = sorted(n for n in os.listdir(SOCKET_DIR) if n.endswith(".sock"))
        if not names:
            print(f"No sockets in {SOCKET_DIR}", file=sys.stderr)
            sys.exit(1)
        print(f"Socket directory: {SOCKET_DIR}")
        for n in names:
            print(f"  {n}")
        return

    server = MCPServer(preferred_socket=args.socket)

    def sig_handler(_sig, _frame):
        server._shutdown()

    signal.signal(signal.SIGTERM, sig_handler)
    signal.signal(signal.SIGINT, sig_handler)

    try:
        asyncio.run(server.run())
    except (KeyboardInterrupt, SystemExit):
        pass
    finally:
        log.info("MCP server exited")


if __name__ == "__main__":
    main()
