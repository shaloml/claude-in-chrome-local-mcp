    "No tab with id",
    "No such tab",
    "Tab group not found",
    "tabGroupId not found",
)

# Chrome-extension tools that do NOT accept a "tabId" argument. Everything else
# does, and the bridge auto-injects the active tab's id when the caller omits it.
NO_TABID_TOOLS = frozenset({"tabs_context_mcp", "tabs_create_mcp"})

