    filename=os.path.join(LOG_DIR, "claude-code-chrome-mcp.log"),
    level=logging.DEBUG,
    format="%(asctime)s %(levelname)s %(message)s",
)
log = logging.getLogger("claude-code-chrome-mcp")

USERNAME = os.environ.get("USER", os.environ.get("USERNAME", "default"))
SOCKET_DIR = os.environ.get(
    "CHROME_MCP_SOCKET_DIR",
    f"/tmp/claude-mcp-browser-bridge-{USERNAME}",
)

# Reconnect settings
RECONNECT_INTERVAL = 2.0
MAX_RECONNECT_INTERVAL = 30.0

# Socket error texts that mean the cached MCP tab group / active tab is gone
# (the user closed the tab, or Chrome suspended the extension service worker
# and it lost its in-memory state). When seen we drop the cached tab state,
# re-initialize the tab group via tabs_context_mcp(createIfEmpty=True) and
# retry the call once.
STALE_TAB_ERROR_MARKERS = (
